# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
package-lock.json.backup

# ── Environment / secrets ────────────────────────────────────
.env
.env.*
!.env.example

# ── Runtime config overrides (admin panel saves here) ────────
runtime-config.json

# ── Custom / edited model types (wizard saves here) ──────────
model-types.json

# ── Trained models persisted to disk (runtime artifacts) ─────
models/*
!models/.gitkeep

# ── Temporary files ──────────────────────────────────────────
tmp/*
!tmp/.gitkeep

# ── Local CSV test datasets (not distributed) ────────────────
csv_example/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Editor / OS ──────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Claude Code local session files ──────────────────────────
.claude/
